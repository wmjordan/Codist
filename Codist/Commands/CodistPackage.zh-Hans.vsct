					<LocCanonicalName>.Codist.在当前项目查找声明</LocCanonicalName>
				</Strings>
			</Button>
			<Button guid="guidCodistPackageCmdSet" id="SyntaxCustomizeHighlightId" priority="0x0100" type="Button">
				<Parent guid="guidSHLMainMenu" id="IDG_VS_TOOLS_OPTIONS" />
				<Icon guid="ImageCatalogGuid" id="StyleBlock" />
				<CommandFlag>IconIsMoniker</CommandFlag>
				<CommandFlag>DefaultInvisible</CommandFlag>
				<CommandFlag>DynamicVisibility</CommandFlag>
				<Strings>
					<ButtonText>配置 Codist 高级语法样式...</ButtonText>
					<LocCanonicalName>.Codist.配置高级语法样式</LocCanonicalName>
				</Strings>
			</Button>
			<Button guid="guidCodistPackageCmdSet" id="OptionsWindowId" priority="0x0101" type="Button">
				<Parent guid="guidSHLMainMenu" id="IDG_VS_TOOLS_OPTIONS" />
				<Icon guid="ImageCatalogGuid" id="SettingsPanel" />
				<CommandFlag>IconIsMoniker</CommandFlag>
				<Strings>
					<ButtonText>Codist 选项...</ButtonText>
					<CanonicalName>CodistOptions</CanonicalName>
					<LocCanonicalName>.Codist.选项</LocCanonicalName>
				</Strings>
			</Button>
			<Button guid="guidCodistPackageCmdSet" id="CodeRefactoringId" priority="0x1000" type="Button">
				<Parent guid="guidSHLMainMenu" id="IDG_REFACTORING_ADVANCED" />
				<Icon guid="ImageCatalogGuid" id="Refactoring" />
				<CommandFlag>IconIsMoniker</CommandFlag>
				<CommandFlag>DefaultInvisible</CommandFlag>
				<CommandFlag>DynamicVisibility</CommandFlag>
				<CommandFlag>DefaultDisabled</CommandFlag>
				<Strings>
					<MenuText>重构代码...</MenuText>
					<ButtonText>重构代码</ButtonText>
					<ToolTipText>打开重构代码的菜单...</ToolTipText>
					<LocCanonicalName>.Codist.重构代码</LocCanonicalName>
				</Strings>
			</Button>
			<Button guid="guidCodistPackageCmdSet" id="ListWrapTextId" priority="0x1000" type="Button">
				<Parent guid="guidSHLMainMenu" id="IDG_VS_EDIT_COMMANDWELL" />
				<Icon guid="ImageCatalogGuid" id="CorrelationScope" />
				<CommandFlag>IconIsMoniker</CommandFlag>
				<CommandFlag>DefaultInvisible</CommandFlag>
				<CommandFlag>DynamicVisibility</CommandFlag>
				<CommandFlag>DefaultDisabled</CommandFlag>
				<Strings>
					<MenuText>列出环绕文本...</MenuText>
					<ButtonText>列出环绕文本...</ButtonText>
					<ToolTipText>显示环绕文本的菜单，从中选择用于环绕当前选中文本的内容...</ToolTipText>
					<LocCanonicalName>.Codist.列出环绕文本</LocCanonicalName>
				</Strings>
			</Button>
			<Button guid="guidCodistPackageCmdSet" id="WrapRecentTextId" priority="0x1001" type="Button">
				<Parent guid="guidSHLMainMenu" id="IDG_VS_EDIT_COMMANDWELL" />
				<Icon guid="ImageCatalogGuid" id="CorrelationScope" />
				<CommandFlag>IconIsMoniker</CommandFlag>
				<CommandFlag>DefaultInvisible</CommandFlag>
				<CommandFlag>DynamicVisibility</CommandFlag>
				<CommandFlag>DefaultDisabled</CommandFlag>
				<Strings>
					<MenuText>插入上一次的环绕文本</MenuText>
					<ButtonText>插入上一次的环绕文本</ButtonText>
					<ToolTipText>重复插入上次从智能工具条插入的环绕文本...</ToolTipText>
					<LocCanonicalName>.Codist.插入上一次的环绕文本</LocCanonicalName>
				</Strings>
			</Button>
